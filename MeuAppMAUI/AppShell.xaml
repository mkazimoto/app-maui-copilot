<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MeuAppMAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MeuAppMAUI.Views"
    Title="MeuAppMAUI">

    <!--
        TabBar produces a bottom tab bar with no flyout entry.
        Each ShellContent is lazy-loaded via ContentTemplate.
    -->
    <TabBar>
        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Settings"
            Icon="settings.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
