<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MeuAppMAUI.ViewModels"
             x:DataType="vm:SettingsViewModel"
             x:Class="MeuAppMAUI.Views.SettingsPage"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="20">
            <!-- Notifications toggle -->
            <Border Padding="16" StrokeShape="RoundRectangle 8">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="Notifications"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="Receive push notifications"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding NotificationsEnabled}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Language picker -->
            <Border Padding="16" StrokeShape="RoundRectangle 8">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Language"
                           FontAttributes="Bold"
                           FontSize="16"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            SelectedItem="{Binding SelectedLanguage}"
                            VerticalOptions="Center">
                        <Picker.Items>
                            <x:String>English</x:String>
                            <x:String>Português</x:String>
                            <x:String>Español</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Save button pinned to bottom -->
        <Button Grid.Row="1"
                Text="Save Settings"
                Command="{Binding SaveSettingsCommand}"
                IsEnabled="{Binding IsNotBusy}"
                Margin="0,16,0,0" />

    </Grid>

</ContentPage>
